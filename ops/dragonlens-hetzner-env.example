# DragonLens demo VM environment
# Copy this file locally to ops/dragonlens-hetzner-env, fill the secrets,
# and upload that untracked file to /opt/dragonlens/.env on the server.

APP_NAME=DragonLens
DEBUG=False
APP_MODE=public_demo
BACKEND_API_BASE_URL=https://demo.dragon-lens.ai

# Local helper only. Pass this to bootstrap.sh; the app does not need it at runtime.
DB_PASSWORD=replace-me

DATABASE_URL=postgresql+psycopg://dragonlens:replace-me@localhost:5432/dragonlens
KNOWLEDGE_DATABASE_URL=postgresql+psycopg://dragonlens:replace-me@localhost:5432/dragonlens

API_PORT=8000
STREAMLIT_PORT=8501

ADMIN_API_TOKEN=replace-me
KNOWLEDGE_SYNC_TOKEN=replace-me
DEMO_PUBLISH_TOKEN=replace-me
ENCRYPTION_SECRET_KEY=replace-me
