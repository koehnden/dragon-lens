# DragonLens Environment Configuration
# Copy this file to .env and fill in your values

# ── Application ──────────────────────────────────────────────────
APP_NAME=DragonLens
DEBUG=False

# local_admin  = full local dev (runs workers, LLMs, writes)
# public_demo  = read-only demo (no workers, blocks mutations except /admin/)
APP_MODE=local_admin

# Streamlit uses this to reach the API. Set to public URL on the demo VM.
BACKEND_API_BASE_URL=http://localhost:8000

# ── Database ─────────────────────────────────────────────────────
POSTGRES_USER=dragonlens
POSTGRES_PASSWORD=your_pwd
POSTGRES_DB=dragonlens
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://dragonlens:your_pwd@localhost:5432/dragonlens

# Knowledge DB — defaults to DATABASE_URL (PostgreSQL). Set explicitly only to override.
# KNOWLEDGE_DATABASE_URL=sqlite:///./data/knowledge.db

# ── Redis / Celery (not needed for public_demo) ─────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_QUEUE_NAME=dragon-lens

# ── Remote LLM APIs (not needed for public_demo) ────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

KIMI_API_KEY=
KIMI_API_BASE=https://api.moonshot.cn/v1

OPENROUTER_API_KEY=
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# ── Ollama (not needed for public_demo) ──────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_TRANSLATION=qwen2.5:7b
OLLAMA_MODEL_SENTIMENT=qwen2.5:7b
OLLAMA_MODEL_NER=qwen2.5:7b
OLLAMA_MODEL_MAIN=qwen2.5:7b

# ── Sentiment Service (not needed for public_demo) ───────────────
USE_ERLANGSHEN_SENTIMENT=true
SENTIMENT_SERVICE_URL=http://127.0.0.1:8100
SENTIMENT_PORT=8100

# ── API Server ───────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=False

# ── Encryption & Admin Tokens ────────────────────────────────────
# Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
ENCRYPTION_SECRET_KEY=your_secure_encryption_key_here
ADMIN_API_TOKEN=
KNOWLEDGE_SYNC_TOKEN=
DEMO_PUBLISH_TOKEN=

# ── Streamlit ────────────────────────────────────────────────────
STREAMLIT_PORT=8501
